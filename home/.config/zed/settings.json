// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // AI Configuration
  // Enable AI features (agent panel, chat, etc.) but keep inline predictions off
  "cli_default_open_behavior": "new_window",
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "vim_mode": false,
  "helix_mode": false,
  "disable_ai": false,
  "show_edit_predictions": false,
  "features": {
    "edit_prediction_provider": "none",
  },

  // External Agent Servers (OpenCode, Claude Code, etc.)
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },

  // Theme & Icons
  "icon_theme": "Catppuccin Mocha",
  "restore_on_startup": "none",

  // Privacy & Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "title_bar": {
    "show_user_picture": false,
  },

  // Panel Configuration
  "outline_panel": {
    "dock": "right",
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "dock": "right",
  },

  // Editor Behavior
  "soft_wrap": "editor_width",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 5,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show": true,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "centered_layout": {
    "left_padding": 0.08,
    "right_padding": 0.08,
  },

  // Security: Disable edit predictions for sensitive files
  "edit_predictions": {
    "disabled_globs": [
      "**/.env*",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/.dev.vars",
      "**/secrets.yml",
    ],
  },
  "edit_predictions_disabled_in": ["comment"],
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "seed_search_query_from_cursor": "selection",
  "minimap": {
    "show": "never",
  },
  "search": {
    "button": false,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "ui_font_family": "Monaspace Xenon",
  "buffer_font_family": "Monaspace Neon",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },

  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic",
      },
      "comment.doc": {
        "font_style": "italic",
      },
    },
  },
  "terminal": {
    "detect_venv": {
      "on": {
        "directories": [".env", "env", "venv"],
        "activate_script": "default",
      },
    },
  },
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/host_vars/*.yml",
      "**/host_vars/*.yaml",
      "**/playbooks/*.yml",
      "**/playbooks/*.yaml",
      "**playbook*.yml",
      "**playbook*.yaml",
    ],
    "OpenTofu": ["tf"],
    "OpenTofu Vars": ["tfvars", "*tfvars.example"],
  },
  "languages": {
    // Python
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "formatter": "language_server",
    },

    // TypeScript/JavaScript (uses vtsls by default)
    "TypeScript": {
      "formatter": "prettier",
      "language_servers": ["vtsls", "tailwindcss-language-server", "..."],
    },
    "TSX": {
      "formatter": "prettier",
      "language_servers": ["vtsls", "tailwindcss-language-server", "..."],
    },
    "JavaScript": {
      "formatter": "prettier",
      "language_servers": ["vtsls", "tailwindcss-language-server", "..."],
    },

    // Go
    "Go": {
      "language_servers": ["gopls"],
      "formatter": "language_server",
    },

    // Rust
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "formatter": "language_server",
    },

    // Svelte
    "Svelte": {
      "formatter": "prettier",
      "language_servers": [
        "svelte-language-server",
        "tailwindcss-language-server",
        "...",
      ],
    },

    // Bash/Shell
    "Shell Script": {
      "language_servers": ["bash-language-server"],
    },

    // GraphQL
    "GraphQL": {
      "formatter": "prettier",
      "language_servers": ["graphql-language-server", "..."],
    },

    // Swift
    "Swift": {
      "language_servers": ["sourcekit-lsp"],
      "formatter": "language_server",
    },

    "JSON": {
      "formatter": "prettier",
    },
    "Markdown": {
      "formatter": "prettier",
    },
    "TOML": {
      "formatter": "language_server",
    },
  },
  "lsp": {
    // TypeScript/JavaScript
    "vtsls": {
      "settings": {
        "typescript": {
          "tsserver": {
            "maxTsServerMemory": 8092,
          },
        },
      },
    },

    // Go
    "gopls": {
      "initialization_options": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },

    // Rust
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "inlayHints": {
          "bindingModeHints": { "enable": true },
          "closureReturnTypeHints": { "enable": "always" },
          "lifetimeElisionHints": { "enable": "skip_trivial" },
          "parameterHints": { "enable": true },
          "typeHints": { "enable": true },
        },
      },
    },

    // Tailwind CSS
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "classList", "ngClass"],
        "experimental": {
          "classRegex": [],
        },
      },
    },

    // Terraform/OpenTofu
    "terraform-ls": {
      "initialization_options": {
        "experimentalFeatures": {
          "prefillRequiredFields": true,
        },
      },
    },

    // Ansible
    "ansible-language-server": {
      "settings": {
        "ansible": {
          "path": "ansible",
        },
        "executionEnvironment": {
          "enabled": false,
        },
        "python": {
          "interpreterPath": "python3",
        },
        "validation": {
          "enabled": true,
          "lint": {
            "enabled": true,
            "path": "ansible-lint",
          },
        },
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
              "./inventory/*.yaml",
              "hosts.yml",
            ],
          },
        },
      },
    },
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "strict",
        },
        "python": {
          "pythonPath": "~/env/bin/python",
        },
      },
    },
    "taplo": {
      "settings": {
        "array_auto_collapse": false,
      },
    },
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": ["*/*.luarc.json"],
              "url": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
            },
          ],
        },
      },
    },

    // Swift
    "sourcekit-lsp": {
      "initialization_options": {
        "completion": {
          "maxResults": 200,
        },
      },
    },
  },
}
